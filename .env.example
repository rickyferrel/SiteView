# Copy to .env.local for local dev, and set the same vars in the Amplify console for prod.

# Public Mapbox pk. token, prefilled when creating a development and used to seed
# Summit Creek. NEXT_PUBLIC_ so it's available in the browser (Mapbox GL needs it
# client-side). This is a publishable token, not an sk. account secret.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Production Postgres (RDS). Leave unset locally to use the file-backed PGlite dev DB.
# Format: postgresql://USER:PASSWORD@HOST:5432/mapportal?sslmode=require
# DATABASE_URL=

# Optional Postgres tuning (prod). Default pool is small for Lambda-backed SSR.
# PGPOOL_MAX=2
# Set to 1 only if you provide the RDS CA bundle and want full cert verification.
# PGSSL_REJECT_UNAUTHORIZED=0

# Origins allowed to iframe /embed/* (the WordPress site). Space-separated.
# Unset = frameable anywhere. e.g. https://example.com https://www.example.com
# EMBED_FRAME_ANCESTORS=
